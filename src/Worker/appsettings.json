{
  "RabbitMq": {
    "Host": "__RABBITMQ_HOST__",
    "Port": 5672,
    "VHost": "/",
    "Username": "__RABBITMQ_USER__",
    "Password": "__RABBITMQ_PASSWORD__",
    "Exchange": "template.events"
  },
  "ConnectionStrings": {
    "Postgres": "Host=__DB_HOST__;Port=5432;Database=__DB_NAME__;Username=__DB_USER__;Password=__DB_PASSWORD__",
    "Redis": "__REDIS_HOST__:6379"
  },
  "Keycloak": {
    "ServiceClient": {
      "TokenEndpoint": "https://__AUTH_HOST__/realms/__REALM__/protocol/openid-connect/token",
      "ClientId": "__SERVICE_CLIENT_ID__",
      "ClientSecret": "__SERVICE_CLIENT_SECRET__",
      "Scope": ""
    }
  },
  "OpenTelemetry": {
    "OtlpEndpoint": "http://__OTEL_COLLECTOR_HOST__:4317",
    "ServiceName": "template-worker"
  },
  "BackgroundJobs": {
    "CleanupOldSampleItems": {
      "Cron": "0 0 * ? * *",
      "MaxAgeDays": 30
    }
  },
  "Serilog": {
    "Loki": {
      "Endpoint": "http://__LOKI_HOST__:3100"
    }
  },
  "ExternalAuth": {
    "Providers": {
      "Google": {
        "ClientId": "your-google-client-id"
      },
      "Microsoft": {
        "ClientId": "your-microsoft-client-id",
        "Tenant": "common"
      },
      "Apple": {
        "ClientId": "your-apple-client-id"
      }
    }
  }
}
