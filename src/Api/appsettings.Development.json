{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=template;Username=template;Password=template",
    "Redis": "localhost:6379",
    "Valkey": "localhost:6380"
  },
  "RabbitMq": {
    "Host": "localhost",
    "Port": 5672,
    "VHost": "/",
    "Username": "guest",
    "Password": "guest",
    "Exchange": "template.events"
  },
  "Keycloak": {
    "Authority": "http://localhost:8081/realms/template",
    "Audience": "template-api",
    "RolesClaim": "roles",
    "ServiceClient": {
      "TokenEndpoint": "http://localhost:8081/realms/template/protocol/openid-connect/token",
      "ClientId": "template-service",
      "ClientSecret": "template-service-secret",
      "Scope": ""
    }
  },
  "ExternalAuth": {
    "Providers": {
      "Google": {
        "ClientId": "your-google-client-id"
      },
      "Microsoft": {
        "ClientId": "your-microsoft-client-id",
        "Tenant": "common"
      },
      "Apple": {
        "ClientId": "your-apple-client-id"
      }
    }
  },
  "Jwt": {
    "Issuer": "Template",
    "Audience": "Template.Api",
    "SigningKey": "CHANGE_ME_32+_CHARS_LONG_SECRET_KEY",
    "LifetimeMinutes": 15
  },
  "OpenTelemetry": {
    "ServiceName": "template-api",
    "OtlpEndpoint": "http://localhost:4317"
  },
  "Serilog": {
    "Loki": {
      "Endpoint": "http://localhost:3100"
    }
  },
  "RefreshTokens": {
    "Enabled": true,
    "LifetimeDays": 14
  }
}
