{
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=__DB_HOST__;Port=5432;Database=__DB_NAME__;Username=__DB_USER__;Password=__DB_PASSWORD__",
    "Redis": "__REDIS_HOST__:6379",
    "Valkey": "__VALKEY_HOST__:6380"
  },
  "RabbitMq": {
    "HostName": "__RABBITMQ_HOST__",
    "Port": 5672,
    "UserName": "__RABBITMQ_USER__",
    "Password": "__RABBITMQ_PASSWORD__"
  },
  "Keycloak": {
    "Authority": "https://__AUTH_HOST__/realms/__REALM__",
    "Audience": "template-api",
    "RolesClaim": "roles",
    "ServiceClient": {
      "TokenEndpoint": "https://__AUTH_HOST__/realms/__REALM__/protocol/openid-connect/token",
      "ClientId": "__SERVICE_CLIENT_ID__",
      "ClientSecret": "__SERVICE_CLIENT_SECRET__",
      "Scope": ""
    }
  },
  "OpenTelemetry": {
    "ServiceName": "template-api",
    "OtlpEndpoint": "http://__OTEL_COLLECTOR_HOST__:4317"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information"
    }
  }
}
